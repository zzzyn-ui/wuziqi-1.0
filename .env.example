# 环境变量配置示例
# 复制此文件为 .env 并填写实际值，或直接设置系统环境变量

# JWT 密钥（必填，至少256位）
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production-at-least-256-bits

# 数据库配置（可选，未设置则使用 application.yml 中的值）
DB_URL=jdbc:mysql://localhost:3306/gobang?useSSL=false&serverTimezone=UTC&characterEncoding=utf8
DB_USERNAME=root
DB_PASSWORD=root

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
